  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["taskflow", "mysql", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "TaskFlow — MySQL Monitoring",
  "uid": "taskflow-mysql-001",
  "version": 1
}
